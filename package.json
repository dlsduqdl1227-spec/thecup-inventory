{
  "name": "thecup-inventory-cloudflare",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create thecup-inventory-db",
    "db:migrate:local": "wrangler d1 migrations apply thecup-inventory-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply thecup-inventory-db --remote",
    "csv:seed": "node scripts/csv-to-seed-sql.mjs ./scripts/sample-inventory.csv ./scripts/seed.sql"
  },
  "devDependencies": {
    "wrangler": "latest"
  }
}
